{
  "name": "rebook",
  "version": "0.4.19",
  "description": "A modular e-book parsing and rendering library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "miniprogram": "miniprogram_dist",
  "typesVersions": {
    "*": {
      "core/parser": [
        "dist/core/parser.d.ts"
      ],
      "parsers/*": [
        "dist/parsers/*.d.ts"
      ],
      "renderers/*": [
        "dist/renderers/*.d.ts"
      ],
      "adapters": [
        "dist/adapters/index.d.ts"
      ],
      "adapters/*": [
        "dist/adapters/*.d.ts"
      ],
      "exporters": [
        "dist/exporters/index.d.ts"
      ],
      "exporters/*": [
        "dist/exporters/*.d.ts"
      ],
      "search": [
        "dist/search.d.ts"
      ],
      "mcp": [
        "dist/mcp.d.ts"
      ],
      "mcp-server": [
        "dist/mcp-server.d.ts"
      ],
      "utils/reader": [
        "dist/utils/reader.d.ts"
      ]
    }
  },
  "bin": {
    "rebook-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./parsers/*": {
      "types": "./dist/parsers/*.d.ts",
      "import": "./dist/parsers/*.js"
    },
    "./core/parser": {
      "types": "./dist/core/parser.d.ts",
      "import": "./dist/core/parser.js"
    },
    "./renderers/*": {
      "types": "./dist/renderers/*.d.ts",
      "import": "./dist/renderers/*.js"
    },
    "./exporters": {
      "types": "./dist/exporters/index.d.ts",
      "import": "./dist/exporters/index.js"
    },
    "./exporters/*": {
      "types": "./dist/exporters/*.d.ts",
      "import": "./dist/exporters/*.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./utils/reader": {
      "types": "./dist/utils/reader.d.ts",
      "import": "./dist/utils/reader.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "import": "./dist/adapters/*.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js"
    }
  },
  "files": [
    "dist",
    "miniprogram_dist"
  ],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build": "tsc && vite build && npm run build:miniprogram",
    "build:miniprogram": "node scripts/build-miniprogram-dist.mjs",
    "prepare": "npm run build",
    "publish:npm": "node scripts/publish-npm.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "ebook",
    "epub",
    "mobi",
    "azw3",
    "kindle",
    "fb2",
    "cbz",
    "comic",
    "reader",
    "parser",
    "renderer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@chenglou/pretext": "^0.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^22.0.0",
    "@xmldom/xmldom": "^0.9.10",
    "@zip.js/zip.js": "^2.7.52",
    "ai": "^6.0.191",
    "css-tree": "^3.2.1",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.10",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@xmldom/xmldom": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
