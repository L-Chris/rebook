{
  "name": "rebook",
  "version": "0.6.0",
  "description": "A modular e-book parsing and rendering library",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "miniprogram": "miniprogram_dist",
  "typesVersions": {
    "*": {
      "core/content-engine-router": [
        "dist/core/content-engine-router.d.ts"
      ],
      "core/parser": [
        "dist/core/parser.d.ts"
      ],
      "core/fixed-document": [
        "dist/core/fixed-document.d.ts"
      ],
      "core/fixed-page-model": [
        "dist/core/fixed-page-model.d.ts"
      ],
      "core/fixed-text-provider": [
        "dist/core/fixed-text-provider.d.ts"
      ],
      "core/location": [
        "dist/core/location.d.ts"
      ],
      "core/mark-resolver": [
        "dist/core/mark-resolver.d.ts"
      ],
      "core/page-surface": [
        "dist/core/page-surface.d.ts"
      ],
      "core/reader": [
        "dist/core/reader.d.ts"
      ],
      "core/reflowable-page-model": [
        "dist/core/reflowable-page-model.d.ts"
      ],
      "core/reflowable-text-provider": [
        "dist/core/reflowable-text-provider.d.ts"
      ],
      "core/renderer-router": [
        "dist/core/renderer-router.d.ts"
      ],
      "core/surface-pipeline": [
        "dist/core/surface-pipeline.d.ts"
      ],
      "renderers/browser": [
        "dist/renderers/browser/index.d.ts"
      ],
      "renderers/browser/fixed": [
        "dist/renderers/browser/fixed.d.ts"
      ],
      "renderers/browser/pdf-canvas": [
        "dist/renderers/browser/pdf-canvas.d.ts"
      ],
      "renderers/wechat-miniprogram": [
        "dist/renderers/wechat-miniprogram/index.d.ts"
      ],
      "parsers/*": [
        "dist/parsers/*.d.ts"
      ],
      "pdf/platform/node": [
        "dist/pdf/platform/node.d.ts"
      ],
      "pdf/renderers/node-canvas": [
        "dist/pdf/renderers/node-canvas.d.ts"
      ],
      "renderers/*": [
        "dist/renderers/*.d.ts"
      ],
      "adapters": [
        "dist/adapters/index.d.ts"
      ],
      "adapters/*": [
        "dist/adapters/*.d.ts"
      ],
      "exporters": [
        "dist/exporters/index.d.ts"
      ],
      "exporters/*": [
        "dist/exporters/*.d.ts"
      ],
      "search": [
        "dist/search.d.ts"
      ],
      "mcp": [
        "dist/mcp.d.ts"
      ],
      "mcp-server": [
        "dist/mcp-server.d.ts"
      ],
      "plugins/*": [
        "dist/plugins/*.d.ts"
      ],
      "plugins": [
        "dist/plugins/index.d.ts"
      ]
    }
  },
  "bin": {
    "rebook-mcp": "./dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core/content-engine-router": {
      "types": "./dist/core/content-engine-router.d.ts",
      "import": "./dist/core/content-engine-router.js"
    },
    "./parsers/*": {
      "types": "./dist/parsers/*.d.ts",
      "import": "./dist/parsers/*.js"
    },
    "./pdf/platform/node": {
      "types": "./dist/pdf/platform/node.d.ts",
      "import": "./dist/pdf/platform/node.js"
    },
    "./pdf/renderers/node-canvas": {
      "types": "./dist/pdf/renderers/node-canvas.d.ts",
      "import": "./dist/pdf/renderers/node-canvas.js"
    },
    "./core/parser": {
      "types": "./dist/core/parser.d.ts",
      "import": "./dist/core/parser.js"
    },
    "./core/fixed-document": {
      "types": "./dist/core/fixed-document.d.ts",
      "import": "./dist/core/fixed-document.js"
    },
    "./core/fixed-page-model": {
      "types": "./dist/core/fixed-page-model.d.ts",
      "import": "./dist/core/fixed-page-model.js"
    },
    "./core/fixed-text-provider": {
      "types": "./dist/core/fixed-text-provider.d.ts",
      "import": "./dist/core/fixed-text-provider.js"
    },
    "./core/location": {
      "types": "./dist/core/location.d.ts",
      "import": "./dist/core/location.js"
    },
    "./core/mark-resolver": {
      "types": "./dist/core/mark-resolver.d.ts",
      "import": "./dist/core/mark-resolver.js"
    },
    "./core/page-surface": {
      "types": "./dist/core/page-surface.d.ts",
      "import": "./dist/core/page-surface.js"
    },
    "./core/reader": {
      "types": "./dist/core/reader.d.ts",
      "import": "./dist/core/reader.js"
    },
    "./core/reflowable-page-model": {
      "types": "./dist/core/reflowable-page-model.d.ts",
      "import": "./dist/core/reflowable-page-model.js"
    },
    "./core/reflowable-text-provider": {
      "types": "./dist/core/reflowable-text-provider.d.ts",
      "import": "./dist/core/reflowable-text-provider.js"
    },
    "./core/renderer-router": {
      "types": "./dist/core/renderer-router.d.ts",
      "import": "./dist/core/renderer-router.js"
    },
    "./core/surface-pipeline": {
      "types": "./dist/core/surface-pipeline.d.ts",
      "import": "./dist/core/surface-pipeline.js"
    },
    "./renderers/browser": {
      "types": "./dist/renderers/browser/index.d.ts",
      "import": "./dist/renderers/browser.js"
    },
    "./renderers/browser/fixed": {
      "types": "./dist/renderers/browser/fixed.d.ts",
      "import": "./dist/renderers/browser/fixed.js"
    },
    "./renderers/browser/pdf-canvas": {
      "types": "./dist/renderers/browser/pdf-canvas.d.ts",
      "import": "./dist/renderers/browser/pdf-canvas.js"
    },
    "./renderers/wechat-miniprogram": {
      "types": "./dist/renderers/wechat-miniprogram/index.d.ts",
      "import": "./dist/renderers/wechat-miniprogram.js"
    },
    "./renderers/*": {
      "types": "./dist/renderers/*.d.ts",
      "import": "./dist/renderers/*.js"
    },
    "./exporters": {
      "types": "./dist/exporters/index.d.ts",
      "import": "./dist/exporters/index.js"
    },
    "./exporters/*": {
      "types": "./dist/exporters/*.d.ts",
      "import": "./dist/exporters/*.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./mcp-server": {
      "types": "./dist/mcp-server.d.ts",
      "import": "./dist/mcp-server.js"
    },
    "./adapters/*": {
      "types": "./dist/adapters/*.d.ts",
      "import": "./dist/adapters/*.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js"
    },
    "./plugins/*": {
      "types": "./dist/plugins/*.d.ts",
      "import": "./dist/plugins/*.js"
    }
  },
  "files": [
    "dist",
    "miniprogram_dist"
  ],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "build": "tsc && vite build && npm run build:miniprogram",
    "build:miniprogram": "node scripts/build-miniprogram-dist.mjs",
    "prepare": "npm run build",
    "publish:npm": "node scripts/publish-npm.mjs",
    "tts:replay": "node scripts/tts-replay.mjs",
    "tts:auto-replay": "npm run build && node scripts/tts-auto-replay.mjs",
    "tts:llm-benchmark": "npm run build && node scripts/tts-llm-benchmark.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run typecheck && npm test -- --run && npm run verify:package && npm run verify:pdf:perf",
    "verify:package": "node scripts/check-package.mjs",
    "verify:pdf": "npm run verify:package && npm run verify:pdf:perf",
    "verify:pdf:perf": "npm run build && node scripts/benchmark-fixed-document.mjs",
    "benchmark:pdfjs": "npm run build && node scripts/compare-pdfjs.mjs"
  },
  "keywords": [
    "ebook",
    "epub",
    "mobi",
    "azw3",
    "kindle",
    "fb2",
    "cbz",
    "comic",
    "reader",
    "parser",
    "renderer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.65",
    "@chenglou/pretext": "^0.0.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@napi-rs/canvas": "^1.0.0",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^22.0.0",
    "@xmldom/xmldom": "^0.9.10",
    "@zip.js/zip.js": "^2.7.52",
    "ai": "^6.0.191",
    "css-tree": "^3.2.1",
    "fflate": "^0.8.3",
    "linkedom": "^0.18.12",
    "pdfjs-dist": "^6.0.227",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xmldom/xmldom": "^0.9.10",
    "zod": "^4.4.3"
  },
  "peerDependenciesMeta": {
    "@napi-rs/canvas": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@xmldom/xmldom": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
